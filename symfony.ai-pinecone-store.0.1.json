{
    "manifests": {
        "symfony/ai-pinecone-store": {
            "manifest": {
                "add-lines": [
                    {
                        "file": "config/packages/ai.yaml",
                        "position": "after_target",
                        "warn_if_missing": true,
                        "target": "    store:",
                        "content": "        pinecone:\n            default:\n                api_key: '%env(PINECONE_API_KEY)%'\n                index_host: '%env(PINECONE_INDEX_HOST)%'"
                    }
                ],
                "env": {
                    "#1": "PINECONE_API_KEY=",
                    "#2": "PINECONE_INDEX_HOST="
                }
            },
            "files": [],
            "ref": "55604f45c8767af6911fbd92cedb54894726453f"
        }
    }
}
