{
    "manifests": {
        "symfony/ai-cloudflare-store": {
            "manifest": {
                "add-lines": [
                    {
                        "file": "config/packages/ai.yaml",
                        "position": "after_target",
                        "warn_if_missing": true,
                        "target": "    store:",
                        "content": "        cloudflare:\n            default:\n                account_id: '%env(CLOUDFLARE_ACCOUNT_ID)%'\n                api_key: '%env(CLOUDFLARE_API_KEY)%'"
                    }
                ],
                "env": {
                    "#1": "CLOUDFLARE_ACCOUNT_ID=",
                    "#2": "CLOUDFLARE_API_KEY="
                }
            },
            "files": [],
            "ref": "1406d3bdf839a0e587502b279e957ffc00bf746a"
        }
    }
}
