{
    "manifests": {
        "symfony/ai-weaviate-store": {
            "manifest": {
                "add-lines": [
                    {
                        "file": "config/packages/ai.yaml",
                        "position": "after_target",
                        "warn_if_missing": true,
                        "target": "    store:",
                        "content": "        weaviate:\n            default:\n                host: '%env(WEAVIATE_HOST)%'\n                api_key: '%env(WEAVIATE_API_KEY)%'"
                    }
                ],
                "env": {
                    "#1": "WEAVIATE_HOST=http://localhost:8080",
                    "#2": "WEAVIATE_API_KEY="
                }
            },
            "files": [],
            "ref": "5cad78a77d7937ea8d143b2b836f1298a379e911"
        }
    }
}
