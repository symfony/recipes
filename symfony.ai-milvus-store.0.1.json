{
    "manifests": {
        "symfony/ai-milvus-store": {
            "manifest": {
                "add-lines": [
                    {
                        "file": "config/packages/ai.yaml",
                        "position": "after_target",
                        "warn_if_missing": true,
                        "target": "    store:",
                        "content": "        milvus:\n            default:\n                host: '%env(MILVUS_HOST)%'\n                port: '%env(int:MILVUS_PORT)%'"
                    }
                ],
                "env": {
                    "#1": "MILVUS_HOST=localhost",
                    "#2": "MILVUS_PORT=19530"
                }
            },
            "files": [],
            "ref": "9830795e3d6741329323691623f677e3673b8417"
        }
    }
}
